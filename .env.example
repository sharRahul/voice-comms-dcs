# Voice-Comms-DCS / Nimbus environment example
# Copy to .env for local development if you use a dotenv loader.
# The application also supports CLI flags and config/commands.json.
# Do not commit real .env files.

# Dashboard / WebRTC
VCDCS_DASHBOARD_HOST=127.0.0.1
VCDCS_DASHBOARD_PORT=8765
VCDCS_DASHBOARD_TOKEN=
VCDCS_ALLOW_LAN=false

# DCS UDP bridge
VCDCS_DCS_HOST=127.0.0.1
VCDCS_DCS_PORT=10308

# DCS telemetry listener
VCDCS_TELEMETRY_HOST=127.0.0.1
VCDCS_TELEMETRY_PORT=10309

# Ollama local LLM
VCDCS_OLLAMA_BASE_URL=http://127.0.0.1:11434
VCDCS_OLLAMA_MODEL=qwen2.5:0.5b
VCDCS_OLLAMA_TIMEOUT_SECONDS=3

# Whisper.cpp
VCDCS_WHISPER_MODEL=models/whisper/ggml-base.en.bin
VCDCS_WHISPER_CLI_EXE=whisper-cli
VCDCS_WHISPER_TIMEOUT_SECONDS=30

# Piper TTS
VCDCS_PIPER_EXE=piper
VCDCS_PIPER_MODEL=models/piper/en_US-lessac-low.onnx
VCDCS_PIPER_TIMEOUT_SECONDS=30

# SRS optional integration
VCDCS_SRS_ENABLED=false
VCDCS_SRS_EXTERNAL_AUDIO_EXE=C:/Program Files/DCS-SimpleRadio-Standalone/DCS-SR-ExternalAudio.exe
VCDCS_SRS_TIMEOUT_SECONDS=10

# Runtime privacy
VCDCS_EXPOSE_POSITION=false
VCDCS_EXPOSE_MODEL_PATHS=false
